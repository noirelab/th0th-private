# ========================================
# TH0TH - 100% LOCAL-FIRST CONFIGURATION
# ========================================
# Nenhuma dependencia de servicos externos.
# Requer apenas Ollama rodando localmente.
#
# Setup:
#   ./scripts/setup-local-first.sh
#   cp .env.local-first .env
#   bun run start:api
# ========================================

# === DATABASES (Local Only) ===
VECTOR_DB_PATH=./data/chroma
CACHE_DB_PATH=./data/cache.db
KEYWORD_DB_PATH=./data/keyword.db

# === LOCAL EMBEDDINGS (Ollama) ===
# Ollama deve estar rodando em localhost:11434
# Instalar: curl -fsSL https://ollama.com/install.sh | sh
# Iniciar: ollama serve
# Modelos recomendados:
#   ollama pull nomic-embed-text:latest   (768D, bom para texto geral)
#   ollama pull all-minilm:latest         (384D, rapido e leve)
#   ollama pull mxbai-embed-large:latest  (1024D, maior qualidade)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3:latest
OLLAMA_EMBEDDING_DIMENSIONS=1024

# === EXTERNAL SERVICES DISABLED ===
# Sem dependencias de APIs externas
# Descomente e configure se quiser fallback remoto
# MISTRAL_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# COHERE_API_KEY=

# === LLM COMPRESSION DISABLED ===
# Usa compressao rule-based local (code_structure)
# Sem necessidade de API key
RLM_LLM_ENABLED=false
# RLM_LLM_API_KEY=
# RLM_LLM_MODEL=

# === CACHE (Local) ===
L1_CACHE_MAX_SIZE=104857600
L1_CACHE_TTL=300
L2_CACHE_MAX_SIZE=524288000
L2_CACHE_TTL=3600

# === COMPRESSION (Local rule-based) ===
MIN_TOKENS_FOR_COMPRESSION=100
TARGET_COMPRESSION_RATIO=0.7

# === RATE LIMITING ===
REQUESTS_PER_MINUTE=120
TOKENS_PER_MINUTE=200000

# === SECURITY ===
MAX_INPUT_LENGTH=50000
SANITIZE_INPUTS=true

# === LOGGING ===
LOG_LEVEL=info
ENABLE_METRICS=true

# === EMBEDDING CACHE (Local) ===
EMBEDDING_CACHE_DB_PATH=./data/embedding-cache.db
